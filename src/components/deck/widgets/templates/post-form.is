/// テキストやボタンを自由にカスタマイズしてください。

Ui:render([
  Ui:C:container({
    children: [
      Ui:C:mfm({ text: "<center>**クイック投稿**</center>" })
      Ui:C:postFormButton({
        text: "おはよう！"
        rounded: true
        primary: true
        form: {
          text: "おはようございます！"
        }
      })
      Ui:C:postFormButton({
        text: "おやすみ"
        rounded: true
        form: {
          text: "おやすみなさい :zzz:"
        }
      })
    ]
  })
])
