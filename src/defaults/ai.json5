// NoteDeck ai.json5 デフォルト
// AI 設定（API キーは含まない — OS キーチェーンに ai.<provider> で格納）
{
  provider: 'anthropic',
  anthropic: {
    endpoint: 'https://api.anthropic.com',
    model: 'claude-opus-4-7',
  },
  openai: {
    endpoint: 'https://api.openai.com/v1',
    model: 'gpt-4o',
  },
  custom: {
    endpoint: '',
    model: '',
  },

  // 権限: AI に渡してよい操作の許可セット
  // Phase 1 では値の保存のみで enforce しない (Phase 2-5 で段階実装)
  // preset: 'readonly' (default) / 'safe' / 'full' / 'custom'
  permissions: {
    preset: 'readonly',
    custom: {
      'notes.read': true,
      'notes.write': false,
      'notes.react': false,
      'account.read': true,
      'account.write': false,
      'drive.read': true,
      'drive.write': false,
      'network.external': false,
      'clipboard': false,
      'notifications': false,
    },
  },

  // データソース: AI に送る system prompt に含める情報
  // permissions と違い、Phase 1 から即動作する (system prompt 末尾に <notedeck-context> として注入)
  dataSources: {
    preset: 'readonly',
    custom: {
      'currentAccount': true,
      'currentColumn': true,
      'visibleNotes': false,
      'recentConversation': false,
    },
  },

  // HEARTBEAT (Phase 6, #411): AI が定期的に自律起動して未読 / 重要事項を拾う
  // - enabled: false がデフォルト。明示 ON で初めて scheduler が動く
  // - intervalMinutes: 5 〜 1440 (24h)。無人時間が長いほどコスト増大に注意
  // - presets: 有効な preset id (HB-A1 では 'unreadMentions' のみ実装)
  // - denyDuringHeartbeat: heartbeat 中だけ追加で deny する capability id
  //   (default: notes.create で AI が勝手に投稿する暴走を防ぐ)
  heartbeat: {
    enabled: false,
    intervalMinutes: 30,
    presets: [],
    denyDuringHeartbeat: ['notes.create'],
  },
}
